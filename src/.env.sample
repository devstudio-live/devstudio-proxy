# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# MongoDB connection string for integration tests.
# Used by: go test -v -tags integration -run TestMongoAtlas ./...
MONGO_TEST_CONNECTION_STRING=mongodb://<user>:<password>@<host>:27017/?ssl=true&replicaSet=<replica-set>&authSource=admin
